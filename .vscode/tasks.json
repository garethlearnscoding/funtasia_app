{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Funtasia Servers",
      "dependsOn": [
        "Serve App",
        "Tailscale Funnel"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Serve App",
      "type": "shell",
      "command": "npx vite --host",
      "isBackground": true,
      "presentation": {
        "group": "funtasia-servers",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Tailscale Funnel",
      "type": "shell",
      "command": "until curl -s -o /dev/null localhost:5317; do sleep 1; done; tailscale funnel 5317",
      "isBackground": true,
      "presentation": {
        "group": "funtasia-servers",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}
